# .env.cloud.example
# Copy to .env.cloud and fill in real values.
# .env.cloud is gitignored — never commit it.

# --- DB1: managed Supabase project (intake engine) ---
DB1_URL=https://<db1-project-ref>.supabase.co
DB1_KEY=eyJ...
# Transaction Pooler URL — Supabase dashboard > Project Settings > Database > Connection string > Transaction pooler
DB1_POSTGRES_URL=postgresql://postgres.<db1-project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# --- DB2: managed Supabase project (confirmed ledger) ---
DB2_URL=https://<db2-project-ref>.supabase.co
DB2_KEY=eyJ...
DB2_POSTGRES_URL=postgresql://postgres.<db2-project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# --- Grafana Cloud k6 ---
# Get from: https://grafana.com/orgs/<your-org>/apikeys  (type: k6)
K6_CLOUD_TOKEN=<your-grafana-cloud-k6-api-token>
