# .env.cloud.example
# Copy to .env.cloud and fill in real values.
# .env.cloud is gitignored — never commit it.

# --- DB1: managed Supabase project (intake engine) ---
DB1_URL=https://<db1-project-ref>.supabase.co
DB1_KEY=eyJ...

# --- DB2: managed Supabase project (confirmed ledger) ---
DB2_URL=https://<db2-project-ref>.supabase.co
DB2_KEY=eyJ...

# --- Grafana Cloud k6 ---
# Get from: https://grafana.com/orgs/<your-org>/apikeys  (type: k6)
K6_CLOUD_TOKEN=<your-grafana-cloud-k6-api-token>
